{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "owk2-workshop",
  "compatibility_date": "2025-09-24",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "main": "src/server.ts",
  "d1_databases": [
    {
      "binding": "WORKSHOP_DB",
      "database_name": "workshop-db",
      "database_id": "ddd81153-9f08-4489-9af9-ecd5201bd490"
    }
  ],
  "r2_buckets": [
    {
      "binding": "WORKSHOP_IMAGES",
      "bucket_name": "workshop-images"
    }
  ]
}